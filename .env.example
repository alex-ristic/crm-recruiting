CRM_HOST=127.0.0.1
CRM_PORT=8000
CRM_ENV=production
CRM_STATE_FILE=/var/lib/crm-recruiting/crm-state.json
# CRM_STATE_PATH is also accepted as an alias for CRM_STATE_FILE.
CRM_BACKUP_DIR=/var/lib/crm-recruiting/backups
CRM_MAX_BACKUPS=50
CRM_MAX_STATE_BYTES=5242880
CRM_AUTH_REQUIRED=1
CRM_COOKIE_SECURE=1
CRM_SESSION_COOKIE_NAME=crm_recruiting_session
CRM_SESSION_MAX_AGE_SECONDS=43200
ADMIN_USERNAME=admin
# Generate with: python3 -m crm.auth 'replace-with-a-long-password'
ADMIN_PASSWORD_HASH=pbkdf2_sha256$260000$replace_salt$replace_hash
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
SESSION_SECRET=replace-with-a-long-random-secret
